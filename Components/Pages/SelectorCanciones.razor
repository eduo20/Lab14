@page "/Selectordemusica"
@using Lab14.Models
@using Lab14.Services
@inject RegistrosServices MiServicio

<PageTitle>Biblioteca de Música</PageTitle>

<div class="container">
    <h1>Control de Biblioteca de Música</h1>

    <!-- SECCIÓN DE BÚSQUEDA (Requerimiento: Desplegar por artista) -->
    <div class="row mb-4 card p-3">
        <h3>Filtrar por Artista</h3>
        <div class="input-group">
            <input type="text" class="form-control" @bind="busquedaArtista" placeholder="Nombre del artista..." />
            <button class="btn btn-primary" @onclick="Consultar">Buscar</button>
            <button class="btn btn-secondary" @onclick="Limpiar">Ver Todos</button>
        </div>
    </div>

    <!-- SECCIÓN DE DESPLIEGUE -->
    @if (albumesFiltrados == null)
    {
        <p>Cargando datos...</p>
    }
    else
    {
        <div class="row">
            @foreach (var album in albumesFiltrados)
            {
                <div class="col-md-6 mb-3">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h4 class="card-title text-primary">@album.tituloAlbum</h4>
                            <h6 class="card-subtitle mb-2 text-muted">Artista: @album.artistaAlbum</h6>
                            <p><strong>Publicado:</strong> @album.AlbumDate.ToShortDateString()</p>
                            
                            <hr />
                            <h5>Canciones:</h5>
                            <ul class="list-group">
                                @foreach (var cancion in album.ListaCanciones)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        @cancion.tituloCancion - @cancion.artistaCancion
                                        <span class="badge bg-secondary">@cancion.tiempoDuracion</span>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private string busquedaArtista = "";
    private List<Album> albumesFiltrados = new List<Album>();

    // Se ejecuta al entrar a la página
    protected override void OnInitialized()
    {
		
        albumesFiltrados = MiServicio.ObtenerRegistros();
    }

    private void Consultar()
    {
        // Esta es la lógica de filtrado que pide el ejercicio
        if (string.IsNullOrWhiteSpace(busquedaArtista))
        {
            albumesFiltrados = MiServicio.ObtenerRegistros();
        }
        else
        {
            albumesFiltrados = MiServicio.ObtenerRegistros()
                .Where(a => a.artistaAlbum.Contains(busquedaArtista, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }

    private void Limpiar()
    {
        busquedaArtista = "";
        albumesFiltrados = MiServicio.ObtenerRegistros();
    }
}